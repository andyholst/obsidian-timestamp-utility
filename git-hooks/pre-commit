#!/usr/bin/env bash
# pre-commit: strip trailing whitespace from staged text files (auto-fix only).
# Never exits non-zero on a clean diff — loop runs (make loop-*) perform no `git commit`,
# so this hook is inert there and cannot break the loop.
set -uo pipefail

# Text-file extension allowlist (skip anything binary / non-text by default).
ALLOWED_EXT_RE='\.(ts|tsx|js|jsx|json|md|cjs|mjs|py|sh|bash|yml|yaml|txt|toml|cfg|ini|css|html|xml|svg|mk|Makefile|Dockerfile)$'
# Also allow files with no extension (e.g. Makefile, Dockerfile, LICENSE) via a name list.
ALLOWED_NAME_RE='^(Makefile|Dockerfile|LICENSE|CHANGELOG|\.gitignore|\.dockerignore|Justfile|Cargo\.toml|pyproject)$'

changed_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

cleaned=0
for f in $changed_files; do
  # Skip if the path no longer exists (deleted files handled separately).
  [ -f "$f" ] || continue

  base=$(basename "$f")
  case "$f" in
    $ALLOWED_NAME_RE) : ;;
    *) case "$f" in
         *.*) echo "$f" | grep -Eq "$ALLOWED_EXT_RE" || continue ;;
         *) continue ;;
       esac ;;
  esac

  # Skip binary files: `file` reports anything containing "binary".
  if command -v file >/dev/null 2>&1; then
    if file --mime-encoding "$f" 2>/dev/null | grep -qi 'binary'; then
      continue
    fi
  fi

  # Skip files that are not valid UTF-8 (treat as binary) when `iconv` is available.
  if command -v iconv >/dev/null 2>&1; then
    if ! iconv -f UTF-8 -t UTF-8 "$f" >/dev/null 2>&1; then
      continue
    fi
  fi

  # Detect trailing whitespace BEFORE mutating.
  if grep -qE '[[:space:]]+$' "$f"; then
    # Rewrite the file in place, stripping trailing whitespace from every line.
    # Use a temp file to avoid truncating on interrupt.
    # Write the temp file in the same dir when writable; otherwise fall back to
    # $TMPDIR so files under dirs we don't own (e.g. container-owned fixtures)
    # don't abort the hook with "Permission denied".
    d=$(dirname "$f")
    if [ -w "$d" ]; then
      tmp="${f}.twb.$$"
    else
      tmp="$(mktemp 2>/dev/null || echo "/tmp/twb.$$")"
    fi
    if sed 's/[[:space:]]*$//' "$f" > "$tmp" 2>/dev/null && cp "$tmp" "$f" 2>/dev/null; then
      rm -f "$tmp" 2>/dev/null
      git add "$f"
      cleaned=$((cleaned + 1))
    else
      # Could not rewrite in place (unwritable file); leave it untouched.
      rm -f "$tmp" 2>/dev/null
    fi
  fi
done

if [ "$cleaned" -gt 0 ]; then
  echo "pre-commit: stripped trailing whitespace from $cleaned staged file(s)."
fi
# ---------------------------------------------------------------------------
# Secret scanning (gitleaks) of staged content.
# Runs scripts/secret_scanner.py --staged. If a secret is detected the commit is
# BLOCKED (non-zero exit) so leaked credentials never enter history. This replaces
# the broken TruffleHog GitHub Action with a local, repo-owned gitleaks scan.
# ---------------------------------------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SCANNER="${REPO_ROOT}/scripts/secret_scanner.py"
if [ -f "$SCANNER" ]; then
  if ! python3 "$SCANNER" --staged; then
    echo "pre-commit hook: SECRET(S) DETECTED in staged content -- commit blocked." >&2
    echo "pre-commit hook: remove the secret (or rotate it) and re-stage, then commit again." >&2
    echo "pre-commit hook: to scan a specific file: python3 scripts/secret_scanner.py --file <path>" >&2
    exit 1
  fi
else
  echo "pre-commit hook: secret_scanner.py not found at $SCANNER; skipping secret scan." >&2
fi

# Always exit 0 — auto-fix only; never block the commit.
exit 0
