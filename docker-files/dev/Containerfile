FROM ubuntu:24.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      gnupg \
      git \
      make \
      zip \
      dos2unix \
      sed \
      python3 \
      python3-pip \
      python3-venv \
      lsb-release && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    curl -sL https://github.com/git-chglog/git-chglog/releases/download/v0.15.4/git-chglog_0.15.4_linux_amd64.tar.gz -o git-chglog.tar.gz && \
    tar xzf git-chglog.tar.gz && \
    mv git-chglog /usr/local/bin/ && \
    rm git-chglog.tar.gz && \
    chmod +x /usr/local/bin/git-chglog && \
    npm install -g @commitlint/cli @commitlint/config-conventional && \
    curl -fsSL https://dl.dagger.io/dagger/install.sh | sh && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* && curl -fsSL https://opencode.ai/install | bash -

WORKDIR /workspace
ENV PATH="/root/.opencode/bin:$PATH"
VOLUME /workspace

CMD ["make", "help"]